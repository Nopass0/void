# VoidDB Environment Variables
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
VOID_HOST=0.0.0.0
VOID_PORT=7700

# ── Storage ───────────────────────────────────────────────────────────────────
VOID_DATA_DIR=./data
VOID_BLOB_DIR=./blob

# ── Security (⚠ MUST change in production) ────────────────────────────────────
VOID_JWT_SECRET=change-me-to-a-random-32-char-string
VOID_ADMIN_PASSWORD=admin

# ── Logging ───────────────────────────────────────────────────────────────────
VOID_LOG_LEVEL=info

# ── Next.js Admin Panel ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:7700

# ── TLS / SSL / Let's Encrypt ────────────────────────────────────────────────
# VOID_TLS_MODE=acme           # off | file | acme
# VOID_DOMAIN=void.example.com
# VOID_ACME_EMAIL=admin@example.com
# VOID_TLS_CERT=/etc/ssl/certs/void.crt     # file mode only
# VOID_TLS_KEY=/etc/ssl/private/void.key    # file mode only

# ── Benchmark ─────────────────────────────────────────────────────────────────
VOID_URL=http://localhost:7700
PG_DSN=postgres://postgres:postgres@localhost:5432/bench?sslmode=disable
